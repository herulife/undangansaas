<script>
    var imagesGalleries,ImageSwipeitems;
    var setImageSwipe = function(){
        imagesGalleries = document.querySelectorAll(".gallery,#nav-cerita ul img,#nav-cerita .story img");
        ImageSwipeitems = [];
        imagesGalleries.forEach(function(e,i){
            if(e.tagName === "IMG"){
                e.addEventListener("click",function(el){
                    openPhotoSwipe(i);
                });
                var gap = 712 / e.clientWidth;
                var newWidht = 712;
                var newHeight = e.clientHeight * gap;
                var srcImg = e.getAttribute("src");
                ImageSwipeitems.push(
                    {
                        src: srcImg,
                        w: newWidht,
                        h: newHeight
                    }
                );
            }else{
                try{
                    var elementStyle = e.currentStyle || window.getComputedStyle(e, false);
                    var srcImg = elementStyle.backgroundImage.slice(4, -1).replace(/"/g, "");
                    if(srcImg != ""){
                        e.addEventListener("click",function(el){
                            openPhotoSwipe(i);
                        });
                        var gap = 712 / e.clientWidth;
                        var newWidht = 712;
                        var newHeight = e.clientHeight * gap;
                        ImageSwipeitems.push(
                            {
                                src: srcImg,
                                w: newWidht,
                                h: newHeight
                            }
                        );
                    }
                }catch(e){}
            }
        })
    }
    var openPhotoSwipe = function(idx){
        setImageSwipe();
        var pswpElement = document.querySelector('.pswp');
        var options = {
            index:idx,
            history: false,
          	focus: false,
    
            showAnimationDuration: 0,
            hideAnimationDuration: 0,
            shareEl : false,
        };
        var gallery = new PhotoSwipe( pswpElement, PhotoSwipeUI_Default, ImageSwipeitems, options);
        gallery.init();
        gallery.listen('destroy', () => {
          setTimeout(function(){
              document.querySelector(".pswp").className="pswp";
          }, 500);
          console.log("closedd");
        });
    }
    $(document).ready(function(e){
        setImageSwipe();
    });
</script>
