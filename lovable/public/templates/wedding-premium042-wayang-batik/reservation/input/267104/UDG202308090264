<!DOCTYPE html>
<html translate="no">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=0.85,maximum-scale=0.85">
    <link href='https://share.linkundangan.com/icon/linkundangan.ico' rel='shortcut icon'/>
    <link rel="stylesheet" href="/css/bootstrap5.min.css?v=2">
    <link rel="stylesheet" href="/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <link href="https://share.linkundangan.com/css/fonts.css" rel="stylesheet">
    <title>Linkundangan.com</title>
    <style>
         @font-face {
          font-family: 'still';
          src: url("/fonts/still.ttf");
          font-display: swap;
        }
        @font-face {
          font-family: 'roboto';
          src: url("/fonts/roboto.ttf");
          font-display: swap;
        }
        body{
            background-image:url('/images/bg.jpg');
        }
        .card{
            border-radius:12px;
            height: fit-content;
        }
        body {
            color: #454444;
        }
        body{font-family:'dmsans';}.modal.fade{transition:all 1s;top:101%;position: fixed!important;opacity:1!important;display: block!important;}.modal.fade.show{top:1px;}.modal-backdrop{transition:all .5s;}
        hr:not([size]) {
            height: 1px;
            border: 5px dashed;
            background: none;
        }
    </style>
    <style>
        
    </style>
    <link rel="stylesheet" href="https://share.linkundangan.com/AdminLTE/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
</head>
<body>
    <div class="container py-3" >
        <div class="row justify-content-center" style="height: 100vh;">
            <div class="col-md-6">
                <div class="card shadow-lg">
                    <div class="modal-body p-2">
                        <img width="111px" src="/Templates/WEDDING-PREMIUM048/assets/images/leaf.png?v=1"/>
                        <h1 class="fw-bold h4 m-0 mb-2 text-center">Reservasi Tamu <br/> Guest Reservation | RSVP FORM</h1>
                        <h6 class="fw-bold font-weight-bold text-center">(DEMO TEMPLATE WEDDING-PREMIUM042) Hamzah &amp; Anissa</h6><hr/>
                        <p class="text-center my-4" style="line-height: 1.3;font-size;11pt">Isi form reservasi jika kamu berencana hadir<br/>Fill out the reservation form if you plan to attend</p>
                        <form method='post' id='form-input-guestbook' action='https://share.linkundangan.com/reservation/input/267104/UDG202308090264'>
                          <input type="hidden" name="_token" value="hPeirTGiTqlBbXxwqxpwK2mWTYj2mx8Bxgc5V7nG"> 
                          <div>
                              <div class="mb-1">
                                <label><span class="text-danger fw-bold font-weight-bold">*</span> Nama | Name:</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="bg-primary input-group-text rounded-0 text-white" style="height:100%"><i class="fa fa-user"></i></span>
                                    </div>
                                    <input type="text" class="form-control rounded-0" placeholder='Vira' maxlength="50" required value='' name='name'>
                                </div>
                              </div>
                              <div class="mb-1">
                                <label><span class="text-danger fw-bold font-weight-bold">*</span>  Jumlah Yang Ikut | Number of Participants:</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="bg-primary input-group-text rounded-0 text-white" style="height:100%"><i class="fa fa-users"></i></span>
                                    </div>
                                    <input type="number" class="form-control rounded-0" min="1" required name='numb_of_articipants' value="1">
                                </div>
                              </div>
                              <div class="mb-1">
                                <label><span class="text-danger fw-bold font-weight-bold">*</span>  Hadir Pada | Present At:</label>
                                <div class="input-group date" id="reservation_at" data-target-input="nearest">
                                    <div class="input-group-prepend" data-target="#reservation_at" data-toggle="datetimepicker">
                                        <div class="bg-primary input-group-text rounded-0 text-white" style="height:100%"><i class="fa fa-calendar"></i></div>
                                    </div>
                                    <input name="come_at" id="input-reservation_at" type="text" required class="form-control datetimepicker-input" data-target="#reservation_at" value="2026-05-31 03:31:26"/>
                                </div>
                              </div>
                              <div class="mb-1">
                                <label>  No HP | Phone Number:</label>
                                <!--<div class="text-secondary" style="font-size: 12px;">(opsional)</div>-->
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="bg-primary input-group-text rounded-0 text-white" style="height:100%"><i class="fa fa-phone"></i></span>
                                    </div>
                                    <input type="tel" class="form-control rounded-0" placeholder='0857XXXXX' name='phone'>
                                </div>
                              </div>
                              <div class="mb-1">
                                <label>Catatan | Note:</label>
                                <!--<div class="text-secondary" style="font-size: 12px;">(opsional)</div>-->
                                <textarea class="form-control rounded-0" placeholder='Datang bersama istri dan anak' name='note'></textarea>
                              </div>
                          </div>
                          <div class="spinner-border" role="status">
                              <span class="visually-hidden">Loading...</span>
                            </div>
                          <div class="modal-footer mt-3">
                            <input type="hidden" name="submit" value="submit"/>
                            <button type="button" class="btn btn-reset btn-warning px-4 rounded-pill">
                                RESET
                            </button>
                            <button class="btn btn-submit btn-primary">
                                Kirim | Submit
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:19px">
                                  <path d="M10 5.9296875L8.5 7.4296875L13.070312 12L8.5 16.570312L10 18.070312L16.070312 12L10 5.9296875 z" fill="white"></path>
                                </svg>
                            </button>
                          </div>
                          <div class="text-center">Data Saat Ini | Current Data</div>
                          <div class="d-flex text-center">
                              <div class="col-6 p-2">
                                  <div class="bg-primary text-white p-2 rounded shadow">
                                    <h5 class="display-5 ff-aero" id="count">7</h5><div>Reservasi <br/> Reservation</div>
                                  </div>
                              </div>
                              <div class="col-6 p-2">
                                  <div class="bg-success text-white p-2 rounded shadow">
                                    <h5 class="display-5 ff-aero" id="sum">286</h5><div>Yang Akan Hadir <br/> Who will attend</div>
                                  </div>
                              </div>
                          </div>
                          <div class="text-center">
                              <span class="badge bg-success fs-6 fw-light text-message px-5 py-3 rounded-pill" style="display: none;">
                                	<i class="fa fa-check"></i> Thank You
                              </span>
                          </div>
                        </form>
                        <div class="text-end">
                            <img width="122px" class="float-end" src="/Templates/WEDDING-PREMIUM048/assets/images/leaf.png?v=1"/>
                        </div>
                    </div>
                </div>
            </div>    
        </div>
        <div class="modal fade" id="thanksModal" tabindex="-1" aria-labelledby="thanksModalLabel" aria-hidden="true" style="background-image: url(https://i.pinimg.com/474x/de/71/18/de71188c1a1f6e0c70810db18e60581a.jpg);background-position: center;background-size: contain;">
          <div class="modal-dialog" style="top: 50%;transform: translate(0, -50%);">
            <div class="modal-content border-0 text-center py-5 rounded-pill shadow-lg" style="background-color: #ffffffa8;" >
              <div class="modal-body">
                  <h5 class="display-5 ff-wedding my-3">Thank You</h5>
                  <p class="ff-mossion mt-2">we are waiting for your presence<br/>Kami tunggu kehadiranmu<br/>&#128522;</p>
                  <button type="button" class="btn btn-outline-primary btn-sm fw-bold px-5 rounded-pill" data-bs-dismiss="modal">Close</button>
              </div>
            </div>
          </div>
        </div>
    </div>
    <script src="https://share.linkundangan.com/js/bootstrap5.bundle.min.js"></script>
    <script src="https://share.linkundangan.com/js/jquery.min.js"></script>
    <script src="https://share.linkundangan.com/js/axios.min.js"></script>
    <script src="/AdminLTE/plugins/moment/moment.min.js"></script>
    <script src="https://share.linkundangan.com/AdminLTE/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <script>
        var thanksModal = new bootstrap.Modal(document.getElementById('thanksModal'), {
          keyboard: false
        });
        $(".btn-reset").on("click",function(e){
            e.preventDefault();
            document.querySelector("#form-input-guestbook").reset();
            document.querySelector(".btn-submit").disabled=false;
            $(".text-message").hide();
        });
        $("#form-input-guestbook").on("submit",function(e){
            e.preventDefault();
            const formData = new FormData(this);
            document.querySelector(".btn-submit").disabled=true;
            axios.post(this.action, formData).then(function (response) {
                if(response.data.status=='SUCCESS'){
                    thanksModal.show();
                    $(".text-message").show();
                    $("#count").text(response.data.count);
                    $("#sum").text(response.data.sum);
                }else{
                    document.querySelector(".btn-submit").disabled=false;
                }
            });
        });
        $(function () {
            $('#reservation_at').datetimepicker({ icons: { time: 'far fa-clock' },format: 'YYYY-MM-DD HH:mm', });
        });
    </script>
    <script>
        
    </script>
</body>
</html>